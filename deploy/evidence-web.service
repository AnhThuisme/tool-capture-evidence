[Unit]
Description=Evidence Tool Web (FastAPI)
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/evidence-web
EnvironmentFile=/opt/evidence-web/.env
ExecStart=/opt/evidence-web/.venv/bin/uvicorn web_ui:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
