# Web server
HOST=0.0.0.0
PORT=8000

# App paths
EVIDENCE_BASE_DIR=
GOOGLE_CREDENTIALS_PATH=
EVIDENCE_WDM_DIR=

# Web auth
WEB_SESSION_SECRET=
WEB_SESSION_MAX_AGE_SEC=43200
WEB_LOGIN_ALLOWED_EMAILS=
WEB_ADMIN_EMAILS=
WEB_AUTH_OTP_TTL_SEC=600
WEB_AUTH_RESEND_COOLDOWN_SEC=45
WEB_AUTH_MAX_ATTEMPTS=6
WEB_AUTH_USE_OUTLOOK=0

# Gmail OTP
GMAIL_SMTP_EMAIL=
GMAIL_SMTP_APP_PASSWORD=
GMAIL_SMTP_FROM_EMAIL=

# Generic SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=1
SMTP_USE_SSL=0
